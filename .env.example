# Copy this file to .env and edit it only for the online version.
# Leave everything unset to run fully offline on a local SQLite file.

# Online warehouse: Supabase or any Postgres. Find this string in your
# Supabase project under Settings -> Database -> Connection string (URI),
# then prefix it with the SQLAlchemy driver, postgresql+psycopg2://
# DATABASE_URL=postgresql+psycopg2://postgres:YOUR-PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres

# Where ete3 keeps its NCBI taxonomy copy. Optional.
# NCBI_TAXA_DB=/full/path/to/taxa.sqlite

# Xeno-canto API v3 key. Optional; if set the audio fetcher prefers it
# over Wikipedia. Get one at https://xeno-canto.org/account
# XENO_CANTO_API_KEY=your-key-here

# Admin password for the dashboard's override controls. Leave unset to
# keep the app fully open (anyone can edit). Set to a string to gate the
# personalization and species-profile-override editors.
# ADMIN_PASSWORD=your-password-here
